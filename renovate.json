{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "lockFileMaintenance": {
    "enabled": true,
  },
  "ignorePaths": [
    "**/requirements.txt"
  ],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["sourcepole/qwc-uwsgi-base"],
      "versioning": "loose"
    }
  ]
}
